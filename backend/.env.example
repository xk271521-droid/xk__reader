# Copy this file to backend/.env and fill in the real server values.
# DATABASE_URL still has the highest priority if you prefer a single connection string.
# DATABASE_URL=mysql+pymysql://xk_reader_user:your_password@your.server.host:3306/xk_reader?charset=utf8mb4

DB_DRIVER=mysql+pymysql
DB_HOST=your.server.host
DB_PORT=3306
DB_USER=xk_reader_user
DB_PASSWORD=your_password
DB_NAME=xk_reader
DB_CHARSET=utf8mb4

DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_POOL_TIMEOUT_SECONDS=30

JWT_SECRET_KEY=change-me-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
SECRET_KEY=change-me-before-production

ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
UPLOADS_DIR=uploads
AVATAR_UPLOAD_DIR=uploads/avatars
PAPERS_UPLOAD_DIR=uploads/papers

# Optional: mirror every local upload to the production server over SFTP.
UPLOAD_MIRROR_ENABLED=false
UPLOAD_MIRROR_REMOTE_DIR=/www/xk-reader/backend/uploads
UPLOAD_MIRROR_SFTP_HOST=47.99.141.123
UPLOAD_MIRROR_SFTP_PORT=22
UPLOAD_MIRROR_SFTP_USERNAME=root
UPLOAD_MIRROR_SFTP_PASSWORD=
UPLOAD_MIRROR_TIMEOUT_SECONDS=15

OPENAI_API_KEY=
DEFAULT_GLM_API_KEY=
DEFAULT_DEEPSEEK_API_KEY=

BAIDU_TRANSLATE_APPID=
BAIDU_TRANSLATE_SECRET=
ALIYUN_DOCMIND_ENABLED=false
ALIYUN_DOCMIND_ACCESS_KEY_ID=
ALIYUN_DOCMIND_ACCESS_KEY_SECRET=
ALIYUN_DOCMIND_ENDPOINT=docmind-api.cn-hangzhou.aliyuncs.com
ALIYUN_DOCMIND_REGION=cn-hangzhou
TENCENT_MT_ENABLED=false
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_MT_REGION=ap-guangzhou
TRANSLATION_ENGINE=ai

SMS_PROVIDER_ORDER=huyi
EMAIL_PROVIDER_ORDER=smtp
VERIFICATION_CODE_TTL_SECONDS=300
VERIFICATION_CODE_RESEND_COOLDOWN_SECONDS=60
VERIFICATION_CODE_MAX_ATTEMPTS=5
HUYI_SMS_ENABLED=false
HUYI_SMS_API_ID=
HUYI_SMS_API_KEY=
HUYI_SMS_ENDPOINT=https://106.ihuyi.com/webservice/sms.php?method=Submit
SMS_CODE_TEMPLATE=您的验证码是：{code}。请不要把验证码泄露给其他人。
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=XK 阅读
SMTP_USE_SSL=true
